{
  "name": "catena-x402-ack-id-demo",
  "version": "0.1.0",
  "description": "Reference demo: ACK-ID (did:web + JWT) identity verification gating an x402 USDC payment on Base Sepolia",
  "license": "MIT",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "seller": "tsx src/seller/main.ts",
    "demo:valid": "tsx scripts/demo.ts valid",
    "demo:missing-identity": "tsx scripts/demo.ts missing-identity",
    "demo:mismatched-identity": "tsx scripts/demo.ts mismatched-identity",
    "demo:expired-identity": "tsx scripts/demo.ts expired-identity",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentcommercekit/did": "0.10.1",
    "@agentcommercekit/jwt": "0.9.0",
    "@agentcommercekit/keys": "0.9.0",
    "@x402/core": "2.19.0",
    "@x402/evm": "2.19.0",
    "@x402/express": "2.19.0",
    "@x402/fetch": "2.19.0",
    "express": "^5.1.0",
    "viem": "^2.31.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.0",
    "eslint": "^9.30.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  }
}
