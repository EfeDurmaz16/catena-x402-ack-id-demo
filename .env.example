# --- Required for the real-payment path (demo:valid) ---

# Address that receives the USDC payment (any Base Sepolia address you control).
SELLER_PAY_TO_ADDRESS=

# Private key of the buyer wallet. Must hold Base Sepolia USDC
# (free from https://faucet.circle.com, select "Base Sepolia").
# Generate a throwaway key: pnpm exec tsx scripts/new-wallet.ts
# NEVER use a mainnet key here.
BUYER_EVM_PRIVATE_KEY=

# --- Optional (sensible defaults) ---

# x402 facilitator endpoint (the settlement adapter's public surface).
# Default is the public testnet facilitator. Point this at the Catena
# sandbox facilitator endpoint once Catena publishes one.
#X402_FACILITATOR_URL=https://x402.org/facilitator

# CAIP-2 network id. Default: Base Sepolia.
#X402_NETWORK=eip155:84532

# Price of the protected endpoint and the authorization stub's per-request cap.
#ENDPOINT_PRICE_USD=$0.001
#AUTHORIZATION_MAX_USD=$0.05

# Local ports.
#SELLER_PORT=4021
#BUYER_DID_PORT=4022
